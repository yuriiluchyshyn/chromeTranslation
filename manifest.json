{
  "manifest_version": 3,
  "name": "Text Translator to Ukrainian",
  "version": "1.0",
  "description": "Simple extension to translate selected text to Ukrainian",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Text Translator"
  }
}